# App (production | staging | development)
ENVIRONMENT=development

# Server port (default 3000)
PORT=3000

# JWT

JWT_SECRET=secret
JWT_ACCESS_TOKEN_EXPIRES_IN=1h
JWT_REFRESH_TOKEN_EXPIRES_IN=30d
JWT_ISSUER=issuer

# Cometchat
COMETCHAT_API_URL=
COMETCHAT_API_KEY=

# DO space
SPACES_ACCESS_KEY_ID=
SPACES_SECRET_ACCESS_KEY=
SPACES_BUCKET_NAME=

# Email
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USERNAME=
EMAIL_PASSWORD=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Sendgrid
SENDGRID_API_KEY=

# Admin
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=

# Onesignal (use your own keys)
ONESIGNAL_USER_AUTH_KEY=
ONESIGNAL_REST_API_KEY=
ONESIGNAL_APP_ID=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379



# Database
DATABASE_URL=
DB_SSL_CERT=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ZEGO
ZEGO_APP_ID=
ZEGO_SERVER_SECRET=

# SWAGGER
SWAGGER_USER=
SWAGGER_PASSWORD=
