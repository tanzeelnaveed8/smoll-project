# App (Expo) – used by app.config.js so the app talks to your backend.
# Copy to .env and set your values. .env is gitignored.
# After changing .env, restart Expo (expo start -c).

# Backend API base URL. Required for Get OTP / login to work.
# - Android emulator: http://10.0.2.2:3000
# - iOS simulator:    http://localhost:3000
# - Physical device:  http://YOUR_PC_IP:3000 (e.g. http://192.168.1.5:3000)
API_URL=http://10.0.2.2:3000
# Socket server URL (e.g. same host as API with different port)
SOCKET_URL=http://10.0.2.2:3000
# Optional: Sentry DSN for error reporting
SENTRY_DSN=
