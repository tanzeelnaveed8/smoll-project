# App (Expo) – used by app.config.js so the app talks to your backend.
# Copy to .env and set your values. .env is gitignored.

# Backend API base URL (e.g. https://api.yourdomain.com)
API_URL=
# Socket server URL (e.g. https://socket.yourdomain.com)
SOCKET_URL=
# Optional: Sentry DSN for error reporting
SENTRY_DSN=
